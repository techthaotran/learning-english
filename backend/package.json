{
  "name": "learning-english-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint \"src/**/*.ts\"",
    "build": "tsc",
    "check": "pnpm lint && tsc",
    "start": "node dist/index.js",
    "dev:prepare": "tsc",
    "dev:watch": "tsc -w --preserveWatchOutput",
    "dev:run": "node --watch dist/index.js",
    "dev": "pnpm dev:prepare && concurrently -k -n tsc,api -c yellow,green \"pnpm dev:watch\" \"pnpm dev:run\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "swagger-jsdoc": "^6.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "concurrently": "^9.1.2",
    "eslint": "^10.4.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
